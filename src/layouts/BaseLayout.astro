---
import BaseHead from '../components/BaseHead.astro';
import { Nav } from '../components/react/Nav';
import { Footer } from '../components/react/Footer';
import { WhatsAppFAB } from '../components/react/WhatsAppFAB';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  darkHero?: boolean;
}
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="relative min-h-screen bg-background text-foreground">
    <Nav base={base} client:load />
    <main>
      <slot />
    </main>
    <Footer base={base} client:visible />
    <WhatsAppFAB client:visible />
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PageHero } from '../components/react/PageHero';
import { Contact } from '../components/react/Contact';
import { ContactOffices } from '../components/react/ContactOffices';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
---

<BaseLayout
  title="Contact - Yakuver Solutions LTD"
  description="Talk to the Yakuver team about your project. Send scope, drawings or a sketch and we'll respond within 24 hours. Accra · Kumasi · Lomé."
>
  <PageHero
    eyebrowKey="page.contact.eyebrow"
    titleKey="page.contact.title"
    accentKey="page.contact.accent"
    ledeKey="page.contact.lede"
    crumbs={[{labelKey:"crumb.home",href:b},{labelKey:"crumb.contact",href:b+"contact/"}]}
    client:load
  />

  <Contact client:visible />
  <ContactOffices client:visible />
</BaseLayout>

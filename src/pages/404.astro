---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Error404 } from '../components/react/Error404';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="404 - Lost on site · Yakuver Solutions LTD"
  description="Page not found. Return to the Yakuver Solutions homepage or get in touch with the team."
>
  <Error404 base={base} client:load />
</BaseLayout>

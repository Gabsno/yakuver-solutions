---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PageHero } from '../components/react/PageHero';
import { Anatomy } from '../components/react/Anatomy';
import { Beliefs } from '../components/react/Beliefs';
import { Process } from '../components/react/Process';
import { Team }    from '../components/react/Team';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
---

<BaseLayout
  title="About - Yakuver Solutions LTD"
  description="Yakuver Solutions LTD is a multidisciplinary firm with a strong focus on Architectural and Civil Engineering - delivering integrated services from planning and construction to MEPF systems across Ghana and West Africa."
>
  <PageHero
    eyebrowKey="page.about.eyebrow"
    titleKey="page.about.title"
    accentKey="page.about.accent"
    ledeKey="page.about.lede"
    crumbs={[{labelKey:"crumb.home",href:b},{labelKey:"crumb.about",href:b+"about/"}]}
    client:load
  />

  <Anatomy base={base} client:visible />
  <Beliefs client:visible />
  <Process client:visible />
  <Team    client:visible />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero   from '../../components/PageHero.astro';
import { Gallery } from '../../components/react/Gallery';
import { PROJECTS, CASE_STUDIES } from '../../lib/projects';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';

type ImageMetadata = { src: string; width: number; height: number; format: string };
const imageMods = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/projects/*.{jpg,jpeg,png,webp}',
  { eager: true },
);
const resolveImg = (file: string) =>
  (imageMods as Record<string, { default: ImageMetadata }>)[`../../assets/projects/${file}`]?.default ?? null;
---

<BaseLayout
  title="Projects - Yakuver Solutions LTD"
  description="A live portfolio of architecture, civil and MEPF projects across Ghana and Togo - commercial, residential, healthcare and institutional builds totalling over GH₵ 60M in active scope."
>
  <PageHero
    eyebrow="Projects"
    title="A live portfolio"
    accent="across Ghana & Togo."
    lede="Commercial complexes, hospitals, residential apartments and institutional buildings. A representative selection of work in commission or recently delivered."
    crumbs={[
      { label: 'Home',     href: b },
      { label: 'Projects', href: b + 'projects/' },
    ]}
  />

  <!-- Featured case studies - cards that link to /projects/[slug] -->
  <section class="py-20 lg:py-24 bg-background border-b border-line">
    <div class="max-w-[1480px] mx-auto px-6 lg:px-10">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-9">
        <h2 class="font-heading font-black text-[clamp(1.6rem,3vw,2.4rem)] text-primary leading-[1.1]">
          Featured case studies
        </h2>
        <span class="font-mono text-[11px] tracking-[0.16em] uppercase text-secondary-2">
          ◆ click any card for the full write-up
        </span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
        {CASE_STUDIES.map((c) => {
          const heroImg = resolveImg(c.hero);
          return (
            <a
              href={b + 'projects/' + c.slug + '/'}
              class="group block bg-paper border border-line rounded-lg+ overflow-hidden shadow-soft hover:shadow-medium hover:border-gold/40 hover:-translate-y-1 transition-all duration-300"
            >
              <div class="aspect-[4/3] overflow-hidden bg-primary">
                {heroImg && (
                  <img
                    src={heroImg.src}
                    alt={c.name}
                    width={heroImg.width}
                    height={heroImg.height}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                  />
                )}
              </div>
              <div class="p-5">
                <div class="font-mono text-[10.5px] tracking-[0.16em] uppercase text-gold-deep font-semibold mb-1.5">
                  {c.location} · {c.sector}
                </div>
                <h3 class="font-heading font-bold text-[16px] text-primary leading-snug mb-2 group-hover:text-gold-deep transition-colors">
                  {c.name}
                </h3>
                <div class="flex items-center justify-between pt-3 border-t border-line mt-3">
                  <span class="font-mono text-[12px] font-semibold text-primary">{c.value}</span>
                  <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-sm- font-mono text-[9.5px] tracking-[0.1em] uppercase font-bold ${
                    c.status === 'ongoing'
                      ? 'bg-gold/10 text-gold-deep border border-gold/30'
                      : 'bg-green-500/10 text-green-700 border border-green-500/30'
                  }`}>
                    {c.status === 'ongoing' ? 'Ongoing' : 'Completed'}
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Full project table -->
  <section class="py-20 lg:py-24 bg-paper">
    <div class="max-w-[1480px] mx-auto px-6 lg:px-10">
      <h2 class="font-heading font-black text-[clamp(1.6rem,3vw,2.4rem)] text-primary leading-[1.1] mb-9">
        Full portfolio
      </h2>
      <div class="rounded-lg+ overflow-hidden border border-line bg-paper shadow-soft">
        <div class="hidden lg:grid grid-cols-[60px_1.5fr_2fr_1fr_120px] px-6 py-4 bg-primary text-on-primary/60 font-mono text-[10.5px] tracking-[0.18em] uppercase gap-4">
          <div>#</div>
          <div>Project</div>
          <div>Scope & phase</div>
          <div>Value</div>
          <div class="text-right">Status</div>
        </div>

        {PROJECTS.map((r) => (
          r.slug ? (
            <a
              href={b + 'projects/' + r.slug + '/'}
              class="grid grid-cols-1 lg:grid-cols-[60px_1.5fr_2fr_1fr_120px] gap-2 lg:gap-4 px-6 py-5 lg:py-6 border-b border-line last:border-b-0 items-center hover:bg-gold/[0.06] hover:pl-9 transition-all duration-200"
            >
              <div class="font-mono text-[12px] text-gold-deep font-semibold">{r.idx}</div>
              <div class="font-heading font-bold text-[16px] text-primary inline-flex items-center gap-2">
                {r.name} <span class="text-gold-2 text-[12px]">→</span>
              </div>
              <div class="text-[13.5px] text-secondary leading-[1.5]">{r.desc}</div>
              <div class="font-mono font-semibold text-primary text-[14px]">{r.value}</div>
              <div class="lg:text-right">
                <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-sm- font-mono text-[10px] tracking-[0.12em] uppercase font-semibold ${
                  r.status === 'ongoing' ? 'bg-gold/10 text-gold-deep border border-gold/30' : 'bg-green-500/10 text-green-700 border border-green-500/30'
                }`}>
                  <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                  {r.status === 'ongoing' ? 'Ongoing' : 'Completed'}
                </span>
              </div>
            </a>
          ) : (
            <div
              class="grid grid-cols-1 lg:grid-cols-[60px_1.5fr_2fr_1fr_120px] gap-2 lg:gap-4 px-6 py-5 lg:py-6 border-b border-line last:border-b-0 items-center"
            >
              <div class="font-mono text-[12px] text-gold-deep font-semibold">{r.idx}</div>
              <div class="font-heading font-bold text-[16px] text-primary">{r.name}</div>
              <div class="text-[13.5px] text-secondary leading-[1.5]">{r.desc}</div>
              <div class="font-mono font-semibold text-primary text-[14px]">{r.value}</div>
              <div class="lg:text-right">
                <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-sm- font-mono text-[10px] tracking-[0.12em] uppercase font-semibold ${
                  r.status === 'ongoing' ? 'bg-gold/10 text-gold-deep border border-gold/30' : 'bg-green-500/10 text-green-700 border border-green-500/30'
                }`}>
                  <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                  {r.status === 'ongoing' ? 'Ongoing' : 'Completed'}
                </span>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <Gallery client:visible />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero   from '../components/PageHero.astro';
import { ServicesDeep } from '../components/react/ServicesDeep';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';

const QUICK_LINKS = [
  { id: 'architecture', label: 'Architecture' },
  { id: 'civil',        label: 'Civil & Structural' },
  { id: 'hvac',         label: 'HVAC & R' },
  { id: 'electrical',   label: 'Electrical' },
  { id: 'plumbing',     label: 'Plumbing' },
  { id: 'fire',         label: 'Fire Protection' },
];
---

<BaseLayout
  title="Services - Architecture, Civil & MEPF · Yakuver Solutions LTD"
  description="Six engineering disciplines delivered by one in-house team - Architectural Consultancy, Civil & Structural Works, HVAC & R Systems, Electrical Systems, Plumbing & Drainage and Fire Protection. Across Ghana and West Africa."
>
  <PageHero
    eyebrow="Services"
    title="Six disciplines."
    accent="One accountable team."
    lede="Architecture, civil and full MEPF - designed, procured, installed and commissioned in-house. Below is a deeper look at each capability and where we've applied it."
    crumbs={[
      { label: 'Home', href: b },
      { label: 'Services', href: b + 'services/' },
    ]}
  />

  <!-- Quick-anchor strip -->
  <nav aria-label="Service quick links" class="bg-background border-b border-line py-5 sticky top-[64px] lg:top-[96px] z-30 backdrop-blur">
    <div class="max-w-[1360px] mx-auto px-6 lg:px-10 flex gap-2 lg:gap-3 overflow-x-auto">
      {QUICK_LINKS.map((q) => (
        <a
          href={`#${q.id}`}
          class="shrink-0 px-3.5 py-2 rounded-full border border-line text-[12.5px] font-mono tracking-[0.06em] uppercase text-secondary hover:border-gold hover:text-primary hover:bg-gold/10 transition-all whitespace-nowrap"
        >
          {q.label}
        </a>
      ))}
    </div>
  </nav>

  <ServicesDeep base={base} client:visible />
</BaseLayout>

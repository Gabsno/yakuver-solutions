---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PageHero } from '../components/react/PageHero';
import { ServiceQuickLinks } from '../components/react/ServiceQuickLinks';
import { ServicesDeep } from '../components/react/ServicesDeep';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
---

<BaseLayout
  title="Services - Architecture, Civil & MEPF · Yakuver Solutions LTD"
  description="Six engineering disciplines delivered by one in-house team - Architectural Consultancy, Civil & Structural Works, HVAC & R Systems, Electrical Systems, Plumbing & Drainage and Fire Protection. Across Ghana and West Africa."
>
  <PageHero
    eyebrowKey="page.services.eyebrow"
    titleKey="page.services.title"
    accentKey="page.services.accent"
    ledeKey="page.services.lede"
    crumbs={[{labelKey:"crumb.home",href:b},{labelKey:"crumb.services",href:b+"services/"}]}
    client:load
  />

  <ServiceQuickLinks client:load />

  <ServicesDeep base={base} client:visible />
</BaseLayout>

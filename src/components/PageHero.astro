---
// =============================================================================
// PageHero — compact dark hero banner used by sub-pages (About, Services,
// Projects, Contact). Carries the page title, eyebrow tag, lede paragraph
// and an optional breadcrumb.
// =============================================================================
interface Crumb { label: string; href: string }
interface Props {
  eyebrow: string;
  title: string;
  /** Optional gold-gradient accent fragment shown after the title */
  accent?: string;
  lede?: string;
  crumbs?: Crumb[];
}
const { eyebrow, title, accent, lede, crumbs } = Astro.props;
---

<section class="relative bg-primary text-on-primary overflow-hidden pt-[180px] pb-20 lg:pt-[210px] lg:pb-24 border-b border-line-dark">
  <div class="absolute inset-0 paper-grid-dark opacity-50 [mask-image:radial-gradient(ellipse_at_top_right,black,transparent_75%)]"></div>
  <div
    class="absolute -right-[10%] -top-[10%] w-[55%] h-[60%] pointer-events-none"
    style="background: radial-gradient(circle, rgba(200,147,46,0.18), transparent 60%);"
  ></div>

  <div class="relative max-w-[1480px] mx-auto px-6 lg:px-10">
    {crumbs && (
      <nav aria-label="Breadcrumb" class="mb-5 font-mono text-[11px] tracking-[0.14em] uppercase text-on-primary/55 flex flex-wrap items-center gap-2">
        {crumbs.map((c, i) => (
          <>
            {i > 0 && <span class="opacity-50">/</span>}
            <a href={c.href} class="hover:text-gold-2 transition-colors">{c.label}</a>
          </>
        ))}
      </nav>
    )}

    <div class="font-mono text-[11.5px] tracking-[0.18em] uppercase text-gold-2 mb-5 inline-flex items-center gap-3">
      <span class="inline-block w-7 h-px bg-current opacity-60"></span>
      {eyebrow}
    </div>

    <h1 class="font-heading font-black tracking-[-0.025em] leading-[1.05] text-[clamp(2.4rem,5.5vw,4.6rem)] max-w-[18ch]">
      {title}
      {accent && <span class="block text-gold-gradient">{accent}</span>}
    </h1>

    {lede && (
      <p class="mt-7 text-on-primary/70 text-[clamp(1.05rem,1.2vw,1.2rem)] leading-[1.65] max-w-[64ch]">
        {lede}
      </p>
    )}
  </div>
</section>
